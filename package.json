{
  "name": "@onward-partners/nx-get-affected-action",
  "version": "3.2.0",
  "description": "This action returns the apps that got affected since the last build",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint src/**/*.ts",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onward-partners/nx-get-affected-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "nx"
  ],
  "author": "scomans",
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.10.1",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-plugin-github": "^6.0.0",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.1",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
